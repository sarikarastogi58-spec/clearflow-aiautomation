# AI support
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Local business discovery (Apify)
APIFY_API_TOKEN=
APIFY_ACTOR_ID=compass~crawler-google-places

# Gmail API OAuth (refresh token and sender are saved after authorization)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# Twilio Calls + SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_VOICE_FROM=
TWILIO_MESSAGING_SERVICE_SID=

# Protect scheduled follow-up and Gmail synchronization jobs
CRON_SECRET=

# Server-side encryption key for dashboard-managed provider credentials
VAULT_MASTER_KEY=

# Deployment defaults
DEFAULT_TIMEZONE=Asia/Kolkata
