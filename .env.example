# AI support
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Local business discovery (Apify)
APIFY_API_TOKEN=
APIFY_ACTOR_ID=compass~crawler-google-places

# Indian SMS (MSG91 Flow + DLT-approved template)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_MESSAGE_VARIABLE=MESSAGE
MSG91_WEBHOOK_TOKEN=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Clear Web Solutions <hello@yourdomain.in>
EMAIL_WEBHOOK_SECRET=

# Optional voice support (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VOICE_FROM=

# Protect scheduled job endpoints
CRON_SECRET=

# Server-side encryption key for dashboard-managed provider credentials
VAULT_MASTER_KEY=

# Deployment defaults
DEFAULT_TIMEZONE=Asia/Kolkata
