# Required
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GOOGLE_PLACES_API_KEY=

# WhatsApp Business Platform
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# SMS and Voice (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Clear Web Solutions <hello@yourdomain.in>
EMAIL_WEBHOOK_SECRET=

# Protect scheduled job endpoints
CRON_SECRET=

# Server-side encryption key for dashboard-managed provider credentials
VAULT_MASTER_KEY=

# Deployment defaults
DEFAULT_TIMEZONE=Asia/Kolkata
